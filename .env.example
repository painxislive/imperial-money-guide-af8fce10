# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Market Data APIs (Optional - for live data in calculators)
VITE_ALPHA_VANTAGE_KEY=your-alpha-vantage-api-key
VITE_FRED_KEY=your-fred-api-key

# JWT Secret for API routes (if implementing server-side auth)
VITE_JWT_SECRET=your-jwt-secret-for-api-routes

# Note: Environment variables prefixed with VITE_ are exposed to the client
# Keep sensitive keys on the server side only in production